generator client {
  provider = "prisma-client"
  output   = "./generated"
  engineType = "library"
}

datasource db {
  provider = "mysql"
}

model FormSubmission {
  id        Int      @id @default(autoincrement())
  name      String   // Имя, фамилия (обязательное)
  phone     String   // Телефон (обязательное)
  email     String   // Email (обязательный)
  message   String   // Сообщение или вопрос (обязательное)
  consent   Boolean  // Согласие на обработку ПД (обязательное)
  files     Json?    // Массив файлов (пути, имена)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}